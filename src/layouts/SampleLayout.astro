---
import NavSidebar from '../components/NavSidebar.astro';

interface Props {
  slug?: string;
  title?: string;
}

const { slug = '', title = 'Ignite UI | Web Components' } = Astro.props;

// True only for the index page (no slug). Used to set the initial nav state.
const isIndex = !slug;
---

<!DOCTYPE html>
<html lang="en" data-sample-slug={slug}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="shortcut icon" href="https://dl.infragistics.com/x/img/browsers/wc.png" />

    <!-- Google Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Kanit&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Titillium+Web" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />

    <!-- Infragistics shared sample stylesheet (shared across all WC samples) -->
    <link rel="stylesheet" href="https://dl.infragistics.com/x/css/samples/shared.v8.css" />
  </head>

  <body>
    <div id="shell">
      <nav id="nav-bar" class="hidden">
        <NavSidebar activeSlug={slug} />
      </nav>

      <script is:inline define:vars={{ isIndex }}>
        (function () {
          var inIframe = window.self !== window.top;
          var fromNav  = sessionStorage.getItem('igx-wc-nav') === '1';

          if (!inIframe && (isIndex || fromNav)) {
            var nav = document.getElementById('nav-bar');
            if (nav) nav.classList.remove('hidden');
          }

          if (isIndex) {
            sessionStorage.setItem('igx-wc-nav', '1');
          }

          if (!isIndex) {
            sessionStorage.removeItem('igx-wc-nav');
          }
        })();
      </script>

      <!-- Sample content area.  The <slot /> receives the sample's HTML. -->
      <main id="router-target">
        <slot />
      </main>
    </div>

    <script>
      // When the user clicks a sidebar nav link, set the sessionStorage flag
      // so the next page load knows to keep the sidebar visible.
      document.getElementById('nav-bar')?.addEventListener('click', e => {
        const link = (e.target as Element).closest('a[data-nav]');
        if (link) sessionStorage.setItem('igx-wc-nav', '1');
      });

      // Expand / collapse component groups.
      document.querySelectorAll<HTMLElement>('.nav-component').forEach(header => {
        const listId = header.getAttribute('aria-controls');
        if (!listId) return;
        const list = document.getElementById(listId);
        if (!list) return;

        header.addEventListener('click', () => {
          const isExpanded = list.dataset.state === 'expanded';
          list.dataset.state = isExpanded ? 'collapsed' : 'expanded';
          header.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
        });
      });

      // Expand the group that contains the active link and scroll it into view
      const activeLink = document.querySelector<HTMLAnchorElement>('a.active');
      if (activeLink) {
        const list = activeLink.closest<HTMLElement>('.nav-list');
        if (list) list.dataset.state = 'expanded';
        // Wait one frame so the list transitions from display:none → display:block
        // before scrollIntoView calculates its position inside #nav-bar.
        requestAnimationFrame(() => {
          activeLink.scrollIntoView({ block: 'nearest', behavior: 'instant' });
        });
      }

      // Search / filter
      const searchInput = document.getElementById('nav-search-input') as HTMLInputElement | null;
      searchInput?.addEventListener('input', () => {
        const q = searchInput.value.trim().toLowerCase();

        document.querySelectorAll<HTMLElement>('#nav-bar section').forEach(section => {
          let sectionHasMatch = false;

          section.querySelectorAll<HTMLElement>('.nav-component').forEach(btn => {
            const listId = btn.getAttribute('aria-controls');
            const list = listId ? document.getElementById(listId) : null;
            if (!list) return;

            let compHasMatch = false;
            list.querySelectorAll<HTMLElement>('li').forEach(li => {
              const match = !q || (li.textContent?.toLowerCase().includes(q) ?? false);
              li.classList.toggle('nav-item-hidden', !match);
              if (match) compHasMatch = true;
            });

            btn.classList.toggle('nav-item-hidden', !compHasMatch);
            if (q && compHasMatch) {
              list.dataset.state = 'expanded';
              btn.setAttribute('aria-expanded', 'true');
            }
            if (compHasMatch) sectionHasMatch = true;
          });

          section.classList.toggle('nav-section-hidden', !sectionHasMatch);
        });

        // On clear: restore original collapsed state (remove inline overrides)
        if (!q) {
          document.querySelectorAll<HTMLElement>('#nav-bar .nav-item-hidden').forEach(el => el.classList.remove('nav-item-hidden'));
          document.querySelectorAll<HTMLElement>('#nav-bar .nav-section-hidden').forEach(el => el.classList.remove('nav-section-hidden'));
          // Re-collapse all lists that weren't previously expanded
          document.querySelectorAll<HTMLElement>('.nav-list').forEach(list => {
            if (list.dataset.state === 'expanded' && !list.contains(document.querySelector('a.active'))) {
              list.dataset.state = 'collapsed';
            }
          });
        }
      });
    </script>
  </body>
</html>

<!-- is:global → Astro emits these selectors WITHOUT scope hashes,
     so they correctly match elements rendered by child components (NavSidebar). -->
<style is:global>
  html, body { width: 100%; height: 100%; margin: 0; }

  /* ── Shell layout ── */
  #shell { display: flex; width: 100%; height: 100%; overflow: hidden; }

  #nav-bar {
    flex-shrink: 0; width: 270px; height: 100%;
    overflow-y: auto; overflow-x: hidden;
    background: #2c2c2c; color: #dbdbdb;
    font-size: medium; font-family: 'Kanit', sans-serif;
    -webkit-user-select: none; user-select: none;
    transition: width 0.15s ease;
  }
  #nav-bar.hidden { width: 0; overflow: hidden; }

  #router-target { flex: 1 1 auto; height: 100%; overflow: auto; position: relative; }

  /* ── Nav links ── */
  #nav-bar a {
    text-decoration: none; display: block;
    padding: 0.25rem 0 0.25rem 0.75rem;
    color: #3e9feb; white-space: nowrap;
  }
  #nav-bar a:hover { background: rgba(204,204,204,0.12); }
  #nav-bar a > span { padding-left: 0.5rem; }
  #nav-bar a.active { background: rgba(62,159,235,0.2); font-weight: bold; }

  /* ── Search input ── */
  .nav-search {
    padding: 6px 8px;
    background: #2c2c2c;
    position: sticky;
    top: 0;
    z-index: 1;
  }
  .nav-search input {
    width: 100%;
    box-sizing: border-box;
    padding: 5px 8px;
    border-radius: 4px;
    border: 1px solid #555;
    background: #1e1e1e;
    color: #dbdbdb;
    font-size: 0.82rem;
    font-family: 'Kanit', sans-serif;
    outline: none;
  }
  .nav-search input::placeholder { color: #888; }
  .nav-search input:focus { border-color: #3e9feb; }

  /* hidden by search filter */
  .nav-item-hidden { display: none !important; }
  .nav-section-hidden { display: none !important; }

  /* ── Group labels ── */
  .nav-group {
    display: block; padding: 10px 0 5px 10px;
    font-size: 0.75rem; text-transform: uppercase;
    letter-spacing: 0.06em; cursor: default; color: #aaaaaa;
    white-space: nowrap;
  }

  .nav-component {
    display: block; width: 100%; cursor: pointer;
    padding: 0.25rem 0.4rem 0.25rem 0.4rem;
    color: #dbdbdb; white-space: nowrap;
    background: none; border: none;
    font: inherit; font-size: medium;
    text-align: left;
  }
  .nav-component:hover { background: rgba(204,204,204,0.12); }
  .nav-component::before {
    content: '\25B6'; /* ▶ right */
    display: inline-block;
    font-size: 0.6rem;
    margin-right: 4px;
    transition: transform 0.15s ease;
    vertical-align: middle;
  }
  .nav-component[aria-expanded="true"]::before {
    transform: rotate(90deg); /* points down */
  }

  /* ── Collapsible lists ── */
  .nav-list {
    margin: 0; padding: 0; list-style: none;
    font-size: medium; font-family: 'Kanit', sans-serif;
    background: rgb(39,39,39);
  }
  .nav-list[data-state="collapsed"] { display: none; }
  .nav-list[data-state="expanded"]  { display: block; }

  /* ── Logo link — reset nav-link styles ── */
  .nav-logo {
    display: block;
    padding: 8px 0;
    text-decoration: none !important;
    color: #dbdbdb !important;
    background: transparent !important;
    line-height: 1;
  }
  .nav-logo:hover { background: rgba(204,204,204,0.08) !important; }
  .nav-logo-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .nav-logo img { display: block; width: 24px; height: 24px; flex-shrink: 0; }
  .nav-logo > .nav-logo-inner > span {
    padding-left: 0 !important;
    font-size: 0.85rem; color: #dbdbdb;
    white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1;
  }

  /* ── Scrollbar ── */
  #nav-bar::-webkit-scrollbar { width: 6px; }
  #nav-bar::-webkit-scrollbar-track { background: #2c2c2c; }
  #nav-bar::-webkit-scrollbar-thumb { background: #555; border-radius: 3px; }
</style>
